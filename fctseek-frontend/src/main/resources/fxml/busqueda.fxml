<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800" prefWidth="1200" style="-fx-background-color: linear-gradient(to bottom, #4facfe 0%, #00f2fe 50%, #87CEEB 100%);" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="com.practicas.controller.BusquedaController">
    
    <top>
        <VBox spacing="15" style="-fx-background-color: transparent;">
            <padding>
                <Insets bottom="15" left="20" right="20" top="20" />
            </padding>
            
            <Label style="-fx-font-family: Arial; -fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" text="Buscar Empresas" />
            
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #FFFFFF; -fx-background-radius: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 8, 0, 0, 2);">
                <padding>
                    <Insets bottom="12" left="15" right="15" top="12" />
                </padding>
                <TextField fx:id="txtBusqueda" prefWidth="500" promptText="Buscar por nombre, sector o ubicacion..." style="-fx-background-color: transparent; -fx-border-width: 0; -fx-font-size: 14px;" HBox.hgrow="ALWAYS" />
                <Button onAction="#limpiarBusqueda" style="-fx-background-color: #E0E0E0; -fx-background-radius: 12; -fx-text-fill: #666666; -fx-cursor: hand;" text="X" />
            </HBox>
            
            <HBox alignment="CENTER_LEFT" spacing="10">
                <padding>
                    <Insets bottom="5" top="10" />
                </padding>
                <Label fx:id="chipTodos" onMouseClicked="#filtrarTodos" style="-fx-background-color: #FFFFFF; -fx-background-radius: 15; -fx-padding: 6 12; -fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: #4facfe; -fx-cursor: hand;" text="Todos" />
                <Label fx:id="chipTecnologia" onMouseClicked="#filtrarTecnologia" style="-fx-background-color: rgba(255,255,255,0.3); -fx-background-radius: 15; -fx-padding: 6 12; -fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: white; -fx-cursor: hand;" text="Tecnologia" />
                <Label fx:id="chipConsultoria" onMouseClicked="#filtrarConsultoria" style="-fx-background-color: rgba(255,255,255,0.3); -fx-background-radius: 15; -fx-padding: 6 12; -fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: white; -fx-cursor: hand;" text="Consultoria IT" />
                <Label fx:id="chipCloud" onMouseClicked="#filtrarCloud" style="-fx-background-color: rgba(255,255,255,0.3); -fx-background-radius: 15; -fx-padding: 6 12; -fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: white; -fx-cursor: hand;" text="Cloud Computing" />
            </HBox>
        </VBox>
    </top>
    
    <center>
        <VBox spacing="10" style="-fx-background-color: transparent;">
            <padding>
                <Insets bottom="10" left="15" right="15" top="10" />
            </padding>
            
            <Label fx:id="lblResultados" style="-fx-font-family: Arial; -fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;" text="x empresas encontradas" />
            
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                <VBox fx:id="listaResultados" spacing="12" style="-fx-background-color: transparent;" />
            </ScrollPane>
        </VBox>
    </center>
    
    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 20 20 0 0; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, -2);">
            <padding>
                <Insets bottom="18" left="10" right="10" top="12" />
            </padding>
            <VBox alignment="CENTER" onMouseClicked="#volverAEmpresas" style="-fx-cursor: hand;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: gray;" text="FCT-Seek" />
            </VBox>
            <VBox alignment="CENTER" style="-fx-cursor: hand;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: #4facfe;" text="Buscar" />
            </VBox>
            <VBox alignment="CENTER" style="-fx-cursor: hand;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: gray;" text="Mis Listas" />
            </VBox>
            <VBox alignment="CENTER" onMouseClicked="#abrirPerfil" style="-fx-cursor: hand;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: gray;" text="Mi Perfil" />
            </VBox>
        </HBox>
    </bottom>
</BorderPane>
