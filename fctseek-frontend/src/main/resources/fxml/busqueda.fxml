<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.practicas.controller.BusquedaController"
            prefWidth="1200" prefHeight="800"
            style="-fx-background-color: linear-gradient(to bottom, #4facfe 0%, #00f2fe 50%, #87CEEB 100%);">
    
    <top>
        <VBox spacing="15" style="-fx-background-color: transparent;">
            <padding>
                <Insets top="20" right="20" bottom="15" left="20"/>
            </padding>
            
            <Label text="Buscar Empresas" style="-fx-font-family: Arial; -fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-background-color: #FFFFFF; -fx-background-radius: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 8, 0, 0, 2);">
                <padding>
                    <Insets top="12" right="15" bottom="12" left="15"/>
                </padding>
                <TextField fx:id="txtBusqueda" promptText="Buscar por nombre, sector o ubicacion..." prefWidth="500" HBox.hgrow="ALWAYS"
                           style="-fx-background-color: transparent; -fx-border-width: 0; -fx-font-size: 14px;"/>
                <Button text="X" onAction="#limpiarBusqueda"
                        style="-fx-background-color: #E0E0E0; -fx-background-radius: 12; -fx-text-fill: #666666; -fx-cursor: hand;"/>
            </HBox>
            
            <HBox alignment="CENTER_LEFT" spacing="10">
                <padding>
                    <Insets top="10" bottom="5"/>
                </padding>
                <Label fx:id="chipTodos" text="Todos" onMouseClicked="#filtrarTodos"
                       style="-fx-background-color: #FFFFFF; -fx-background-radius: 15; -fx-padding: 6 12; -fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: #4facfe; -fx-cursor: hand;"/>
                <Label fx:id="chipTecnologia" text="Tecnologia" onMouseClicked="#filtrarTecnologia"
                       style="-fx-background-color: rgba(255,255,255,0.3); -fx-background-radius: 15; -fx-padding: 6 12; -fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: white; -fx-cursor: hand;"/>
                <Label fx:id="chipConsultoria" text="Consultoria IT" onMouseClicked="#filtrarConsultoria"
                       style="-fx-background-color: rgba(255,255,255,0.3); -fx-background-radius: 15; -fx-padding: 6 12; -fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: white; -fx-cursor: hand;"/>
                <Label fx:id="chipCloud" text="Cloud Computing" onMouseClicked="#filtrarCloud"
                       style="-fx-background-color: rgba(255,255,255,0.3); -fx-background-radius: 15; -fx-padding: 6 12; -fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: white; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </top>
    
    <center>
        <VBox spacing="10" style="-fx-background-color: transparent;">
            <padding>
                <Insets top="10" right="15" bottom="10" left="15"/>
            </padding>
            
            <Label fx:id="lblResultados" text="6 empresas encontradas" style="-fx-font-family: Arial; -fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent;">
                <VBox fx:id="listaResultados" spacing="12" style="-fx-background-color: transparent;"/>
            </ScrollPane>
        </VBox>
    </center>
    
    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 20 20 0 0; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, -2);">
            <padding>
                <Insets top="12" right="10" bottom="18" left="10"/>
            </padding>
            <VBox alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-cursor: hand;" onMouseClicked="#volverAEmpresas">
                <Label text="FCT-Seek" style="-fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: gray;"/>
            </VBox>
            <VBox alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-cursor: hand;">
                <Label text="Buscar" style="-fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: #4facfe;"/>
            </VBox>
            <VBox alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-cursor: hand;">
                <Label text="Mis Listas" style="-fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: gray;"/>
            </VBox>
            <VBox alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-cursor: hand;" onMouseClicked="#abrirPerfil">
                <Label text="Mi Perfil" style="-fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: gray;"/>
            </VBox>
        </HBox>
    </bottom>
</BorderPane>
