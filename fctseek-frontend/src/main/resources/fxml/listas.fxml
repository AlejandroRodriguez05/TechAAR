<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.practicas.controller.ListasController"
            prefWidth="1200" prefHeight="800"
            style="-fx-background-color: linear-gradient(to bottom, #4facfe 0%, #00f2fe 50%, #87CEEB 100%);">
    
    <top>
        <VBox spacing="15" style="-fx-background-color: transparent;">
            <padding>
                <Insets top="20" right="20" bottom="15" left="20"/>
            </padding>
            
            <HBox alignment="CENTER_LEFT">
                <Label text="Mis Listas" style="-fx-font-family: Arial; -fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnCrearLista" text="+ Nueva Lista" onAction="#mostrarDialogoCrearLista"
                        style="-fx-background-color: white; -fx-text-fill: #4facfe; -fx-font-family: Arial; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 10 20; -fx-cursor: hand;"/>
            </HBox>
            
            <Label fx:id="lblSubtitulo" text="Organiza tus empresas favoritas" 
                   style="-fx-font-family: Arial; -fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.8);"/>
        </VBox>
    </top>
    
    <center>
        <VBox spacing="15" style="-fx-background-color: transparent;">
            <padding>
                <Insets top="10" right="15" bottom="10" left="15"/>
            </padding>
            
            <!-- Sección Favoritos -->
            <VBox spacing="10">
                <Label text="⭐ Favoritos" style="-fx-font-family: Arial; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                
                <VBox fx:id="tarjetaFavoritos" onMouseClicked="#abrirFavoritos"
                      style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 3); -fx-cursor: hand;">
                    <padding>
                        <Insets top="15" right="20" bottom="15" left="20"/>
                    </padding>
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <VBox alignment="CENTER" prefWidth="50" prefHeight="50"
                              style="-fx-background-color: #FFD700; -fx-background-radius: 12;">
                            <Label text="⭐" style="-fx-font-size: 24px;"/>
                        </VBox>
                        <VBox spacing="3" HBox.hgrow="ALWAYS">
                            <Label text="Empresas Favoritas" style="-fx-font-family: Arial; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
                            <Label fx:id="lblFavoritosCount" text="0 empresas" style="-fx-font-family: Arial; -fx-font-size: 13px; -fx-text-fill: #888888;"/>
                        </VBox>
                        <Label text="›" style="-fx-font-size: 24px; -fx-text-fill: #CCCCCC;"/>
                    </HBox>
                </VBox>
            </VBox>
            
            <!-- Separador -->
            <Region prefHeight="10"/>
            
            <!-- Sección Mis Listas -->
            <HBox alignment="CENTER_LEFT">
                <Label text="📋 Mis Listas Personalizadas" style="-fx-font-family: Arial; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblListasCount" text="0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 4 12; -fx-font-family: Arial; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4facfe;"/>
            </HBox>
            
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent;">
                <VBox fx:id="listaListas" spacing="12" style="-fx-background-color: transparent;">
                    <!-- Las listas se cargan dinámicamente -->
                </VBox>
            </ScrollPane>
            
            <!-- Estado vacío -->
            <VBox fx:id="estadoVacio" alignment="CENTER" spacing="15" visible="false" managed="false">
                <padding>
                    <Insets top="50"/>
                </padding>
                <Label text="📋" style="-fx-font-size: 48px;"/>
                <Label text="No tienes listas personalizadas" style="-fx-font-family: Arial; -fx-font-size: 16px; -fx-text-fill: white;"/>
                <Label text="Crea una lista para organizar tus empresas" style="-fx-font-family: Arial; -fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.7);"/>
                <Button text="Crear mi primera lista" onAction="#mostrarDialogoCrearLista"
                        style="-fx-background-color: white; -fx-text-fill: #4facfe; -fx-font-family: Arial; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 12 25; -fx-cursor: hand;"/>
            </VBox>
        </VBox>
    </center>
    
    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 20 20 0 0; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, -2);">
            <padding>
                <Insets top="12" right="10" bottom="18" left="10"/>
            </padding>
            <VBox alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-cursor: hand;" onMouseClicked="#volverAEmpresas">
                <Label text="FCT-Seek" style="-fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: gray;"/>
            </VBox>
            <VBox alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-cursor: hand;" onMouseClicked="#abrirBusqueda">
                <Label text="Buscar" style="-fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: gray;"/>
            </VBox>
            <VBox alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-cursor: hand;">
                <Label text="Mis Listas" style="-fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: #4facfe;"/>
            </VBox>
            <VBox alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-cursor: hand;" onMouseClicked="#abrirPerfil">
                <Label text="Mi Perfil" style="-fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: gray;"/>
            </VBox>
        </HBox>
    </bottom>
</BorderPane>
