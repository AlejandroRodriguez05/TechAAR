<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800" prefWidth="1200" style="-fx-background-color: linear-gradient(to bottom, #4facfe 0%, #00f2fe 50%, #87CEEB 100%);" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="com.practicas.controller.EmpresasController">
    
    <top>
        <VBox spacing="15" style="-fx-background-color: transparent;">
            <padding>
                <Insets bottom="10" left="20" right="20" top="20" />
            </padding>
            
            <HBox alignment="CENTER_LEFT">
                <VBox spacing="2">
                    <Label fx:id="lblSaludo" style="-fx-font-family: Arial; -fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;" text="Hola, Usuario" />
                    <Label fx:id="lblInfo" style="-fx-font-family: Arial; -fx-font-size: 13px; -fx-text-fill: white;" text="Alumno - x empresas disponibles" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="btnAdd" onAction="#mostrarDialogoAnadir" prefHeight="40" prefWidth="40" style="-fx-background-color: white; -fx-text-fill: #4facfe; -fx-font-family: Arial; -fx-font-size: 20px; -fx-font-weight: bold; -fx-background-radius: 20; -fx-cursor: hand;" text="+" visible="false" />
            </HBox>
            
            <HBox alignment="CENTER" spacing="15">
                <padding>
                    <Insets bottom="10" top="15" />
                </padding>
                <VBox fx:id="filtroNuevas" alignment="CENTER" onMouseClicked="#filtrarNuevas" style="-fx-background-color: rgba(255,255,255,0.25); -fx-background-radius: 15; -fx-cursor: hand; -fx-padding: 12 20;">
                    <Label style="-fx-font-family: Arial; -fx-font-size: 11px; -fx-text-fill: white;" text="Nuevas" />
                </VBox>
                <VBox fx:id="filtroTop" alignment="CENTER" onMouseClicked="#filtrarTopValoradas" style="-fx-background-color: rgba(255,255,255,0.25); -fx-background-radius: 15; -fx-cursor: hand; -fx-padding: 12 20;">
                    <Label style="-fx-font-family: Arial; -fx-font-size: 11px; -fx-text-fill: white;" text="Top valoradas" />
                </VBox>
                <VBox fx:id="filtroCercanas" alignment="CENTER" onMouseClicked="#filtrarCercanas" style="-fx-background-color: rgba(255,255,255,0.25); -fx-background-radius: 15; -fx-cursor: hand; -fx-padding: 12 20;">
                    <Label style="-fx-font-family: Arial; -fx-font-size: 11px; -fx-text-fill: white;" text="Cercanas" />
                </VBox>
            </HBox>
        </VBox>
    </top>
    
    <center>
        <VBox spacing="10" style="-fx-background-color: transparent;">
            <padding>
                <Insets bottom="10" left="15" right="15" top="10" />
            </padding>
            
            <HBox alignment="CENTER_LEFT">
                <padding>
                    <Insets bottom="10" left="5" right="5" top="5" />
                </padding>
                <Label fx:id="lblTituloSeccion" style="-fx-font-family: Arial; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;" text="Todas las empresas" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblBadge" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 4 12; -fx-font-family: Arial; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #4facfe;" text="x" />
            </HBox>
            
            <ScrollPane fx:id="scrollEmpresas" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                <VBox fx:id="listaEmpresas" spacing="12" style="-fx-background-color: transparent;" />
            </ScrollPane>
        </VBox>
    </center>
    
    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 20 20 0 0; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, -2);">
            <padding>
                <Insets bottom="18" left="10" right="10" top="12" />
            </padding>
            <VBox alignment="CENTER" style="-fx-cursor: hand;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: #4facfe;" text="FCT-Seek" />
            </VBox>
            <VBox alignment="CENTER" onMouseClicked="#abrirBusqueda" style="-fx-cursor: hand;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: gray;" text="Buscar" />
            </VBox>
            <VBox alignment="CENTER" onMouseClicked="#mostrarMisListas" style="-fx-cursor: hand;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: gray;" text="Mis Listas" />
            </VBox>
            <VBox alignment="CENTER" onMouseClicked="#abrirPerfil" style="-fx-cursor: hand;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: gray;" text="Mi Perfil" />
            </VBox>
        </HBox>
    </bottom>
</BorderPane>
