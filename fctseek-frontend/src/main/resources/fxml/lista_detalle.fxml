<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800" prefWidth="1200" style="-fx-background-color: linear-gradient(to bottom, #4facfe 0%, #00f2fe 50%, #87CEEB 100%);" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="com.practicas.controller.ListaDetalleController">
    
    <top>
        <VBox spacing="10" style="-fx-background-color: transparent;">
            <padding>
                <Insets bottom="15" left="20" right="20" top="20" />
            </padding>
            
            <!-- Navegación -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Button onAction="#volverAListas" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-family: Arial; -fx-font-size: 13px; -fx-background-radius: 15; -fx-padding: 8 15; -fx-cursor: hand;" text="← Volver" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="btnEditarLista" onAction="#editarLista" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-family: Arial; -fx-font-size: 13px; -fx-background-radius: 15; -fx-padding: 8 15; -fx-cursor: hand;" text="✏️ Editar" />
                <Button fx:id="btnEliminarLista" onAction="#eliminarLista" style="-fx-background-color: rgba(255,107,107,0.8); -fx-text-fill: white; -fx-font-family: Arial; -fx-font-size: 13px; -fx-background-radius: 15; -fx-padding: 8 15; -fx-cursor: hand;" text="🗑️ Eliminar" />
            </HBox>
            
            <!-- Título de la lista -->
            <VBox spacing="5">
                <Label fx:id="lblNombreLista" style="-fx-font-family: Arial; -fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" text="Mi Lista" />
                <Label fx:id="lblDescripcionLista" style="-fx-font-family: Arial; -fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.8);" text="Descripción de la lista" />
            </VBox>
            
            <!-- Info -->
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Label fx:id="lblEmpresasCount" style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 12; -fx-padding: 6 12; -fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: white;" text="0 empresas" />
                <Label fx:id="lblFechaCreacion" style="-fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.7);" text="Creada: 01/01/2025" />
            </HBox>
        </VBox>
    </top>
    
    <center>
        <VBox spacing="10" style="-fx-background-color: transparent;">
            <padding>
                <Insets bottom="10" left="15" right="15" top="10" />
            </padding>
            
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label style="-fx-font-family: Arial; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;" text="Empresas en esta lista" />
                <Region HBox.hgrow="ALWAYS" />
            </HBox>
            
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                <VBox fx:id="listaEmpresas" spacing="12" style="-fx-background-color: transparent;">
                    <!-- Las empresas se cargan dinámicamente -->
                </VBox>
            </ScrollPane>
            
            <!-- Estado vacío -->
            <VBox fx:id="estadoVacio" alignment="CENTER" managed="false" spacing="15" visible="false" VBox.vgrow="ALWAYS">
                <Label style="-fx-font-size: 48px;" text="📋" />
                <Label style="-fx-font-family: Arial; -fx-font-size: 16px; -fx-text-fill: white;" text="Esta lista está vacía" />
                <Label style="-fx-font-family: Arial; -fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.7);" text="Añade empresas para empezar" />
                <Button onAction="#mostrarDialogoAnadirEmpresa" style="-fx-background-color: white; -fx-text-fill: #4facfe; -fx-font-family: Arial; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 12 25; -fx-cursor: hand;" text="Añadir empresa" />
            </VBox>
        </VBox>
    </center>
    
    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 20 20 0 0; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, -2);">
            <padding>
                <Insets bottom="18" left="10" right="10" top="12" />
            </padding>
            <VBox alignment="CENTER" onMouseClicked="#volverAEmpresas" style="-fx-cursor: hand;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: gray;" text="FCT-Seek" />
            </VBox>
            <VBox alignment="CENTER" onMouseClicked="#abrirBusqueda" style="-fx-cursor: hand;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: gray;" text="Buscar" />
            </VBox>
            <VBox alignment="CENTER" onMouseClicked="#volverAListas" style="-fx-cursor: hand;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: #4facfe;" text="Mis Listas" />
            </VBox>
            <VBox alignment="CENTER" onMouseClicked="#abrirPerfil" style="-fx-cursor: hand;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: gray;" text="Mi Perfil" />
            </VBox>
        </HBox>
    </bottom>
</BorderPane>
