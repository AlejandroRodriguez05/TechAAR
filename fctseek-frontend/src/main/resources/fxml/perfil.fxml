<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.practicas.controller.PerfilController"
            prefWidth="1200" prefHeight="800"
            style="-fx-background-color: linear-gradient(to bottom, #4facfe 0%, #00f2fe 50%, #87CEEB 100%);">
    
    <top>
        <VBox alignment="CENTER" spacing="10" style="-fx-background-color: transparent;">
            <padding>
                <Insets top="20" right="20" bottom="15" left="20"/>
            </padding>
            <Label fx:id="lblNombre" text="Nombre Usuario" style="-fx-font-family: Arial; -fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label fx:id="lblRol" text="Alumno" style="-fx-background-color: rgba(255,255,255,0.3); -fx-background-radius: 15; -fx-padding: 5 15; -fx-font-family: Arial; -fx-font-size: 14px; -fx-text-fill: white;"/>
        </VBox>
    </top>
    
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox alignment="TOP_CENTER" spacing="20" style="-fx-background-color: transparent;">
                <padding>
                    <Insets top="20" right="50" bottom="20" left="50"/>
                </padding>
                
                <VBox fx:id="tarjetaInfo" maxWidth="600" style="-fx-background-color: #FFFFFF; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 10, 0, 0, 3);">
                    
                    <HBox alignment="CENTER_LEFT">
                        <padding>
                            <Insets top="15" right="20" bottom="15" left="20"/>
                        </padding>
                        <Label text="Informacion Personal" style="-fx-font-family: Arial; -fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: black;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <HBox spacing="10">
                            <Button fx:id="btnEditar" text="Editar" onAction="#activarEdicion"
                                    style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-family: Arial; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 15; -fx-padding: 8 20; -fx-cursor: hand;"/>
                            <Button fx:id="btnGuardar" text="Guardar" onAction="#guardarCambios" visible="false" managed="false"
                                    style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-family: Arial; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 15; -fx-padding: 8 20; -fx-cursor: hand;"/>
                            <Button fx:id="btnCancelar" text="Cancelar" onAction="#cancelarEdicion" visible="false" managed="false"
                                    style="-fx-background-color: #9E9E9E; -fx-text-fill: white; -fx-font-family: Arial; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 15; -fx-padding: 8 20; -fx-cursor: hand;"/>
                        </HBox>
                    </HBox>
                    
                    <Region prefHeight="1" style="-fx-background-color: #EEEEEE;"/>
                    
                    <HBox alignment="CENTER_LEFT" spacing="20">
                        <padding>
                            <Insets top="15" right="20" bottom="15" left="20"/>
                        </padding>
                        <Label text="Gmail" prefWidth="100" style="-fx-font-family: Arial; -fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: black;"/>
                        <TextField fx:id="txtEmail" prefWidth="350" prefHeight="35" editable="false"
                                   style="-fx-background-color: #F5F5F5; -fx-border-color: transparent; -fx-background-radius: 5; -fx-padding: 5 10; -fx-text-fill: #333333; -fx-font-size: 14px;"/>
                    </HBox>
                    
                    <Region prefHeight="1" style="-fx-background-color: #EEEEEE;"/>
                    
                    <HBox alignment="CENTER_LEFT" spacing="20">
                        <padding>
                            <Insets top="15" right="20" bottom="15" left="20"/>
                        </padding>
                        <Label text="Pais" prefWidth="100" style="-fx-font-family: Arial; -fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: black;"/>
                        <TextField fx:id="txtPais" prefWidth="350" prefHeight="35" editable="false"
                                   style="-fx-background-color: #F5F5F5; -fx-border-color: transparent; -fx-background-radius: 5; -fx-padding: 5 10; -fx-text-fill: #333333; -fx-font-size: 14px;"/>
                    </HBox>
                    
                    <Region prefHeight="1" style="-fx-background-color: #EEEEEE;"/>
                    
                    <HBox alignment="CENTER_LEFT" spacing="20">
                        <padding>
                            <Insets top="15" right="20" bottom="15" left="20"/>
                        </padding>
                        <Label text="DNI" prefWidth="100" style="-fx-font-family: Arial; -fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: black;"/>
                        <TextField fx:id="txtDni" prefWidth="350" prefHeight="35" editable="false"
                                   style="-fx-background-color: #F5F5F5; -fx-border-color: transparent; -fx-background-radius: 5; -fx-padding: 5 10; -fx-text-fill: #333333; -fx-font-size: 14px;"/>
                    </HBox>
                    
                    <Region prefHeight="1" style="-fx-background-color: #EEEEEE;"/>
                    
                    <HBox alignment="CENTER_LEFT" spacing="20">
                        <padding>
                            <Insets top="15" right="20" bottom="15" left="20"/>
                        </padding>
                        <Label text="Telefono" prefWidth="100" style="-fx-font-family: Arial; -fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: black;"/>
                        <TextField fx:id="txtTelefono" prefWidth="350" prefHeight="35" editable="false"
                                   style="-fx-background-color: #F5F5F5; -fx-border-color: transparent; -fx-background-radius: 5; -fx-padding: 5 10; -fx-text-fill: #333333; -fx-font-size: 14px;"/>
                    </HBox>
                </VBox>
                
                <Button text="Cerrar Sesion" prefWidth="200" prefHeight="45" onAction="#cerrarSesion"
                        style="-fx-background-color: #FF5252; -fx-text-fill: white; -fx-font-family: Arial; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 25; -fx-cursor: hand;"/>
            </VBox>
        </ScrollPane>
    </center>
    
    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 20 20 0 0; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, -2);">
            <padding>
                <Insets top="12" right="10" bottom="18" left="10"/>
            </padding>
            <VBox alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-cursor: hand;" onMouseClicked="#volverAEmpresas">
                <Label text="FCT-Seek" style="-fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: gray;"/>
            </VBox>
            <VBox alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-cursor: hand;" onMouseClicked="#abrirBusqueda">
                <Label text="Buscar" style="-fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: gray;"/>
            </VBox>
            <VBox alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-cursor: hand;">
                <Label text="Mis Listas" style="-fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: gray;"/>
            </VBox>
            <VBox alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-cursor: hand;">
                <Label text="Mi Perfil" style="-fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: #4facfe;"/>
            </VBox>
        </HBox>
    </bottom>
</BorderPane>
