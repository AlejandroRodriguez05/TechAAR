<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.practicas.controller.AnadirAListaDialogController"
      spacing="0"
      style="-fx-background-color: white; -fx-background-radius: 16;"
      prefWidth="380">

    <!-- Cabecera -->
    <VBox style="-fx-background-color: linear-gradient(to right, #4facfe, #00f2fe);
                 -fx-background-radius: 16 16 0 0;"
          spacing="4">
        <padding>
            <Insets top="20" right="24" bottom="18" left="24"/>
        </padding>
        <Label text="+  Añadir a lista"
               style="-fx-font-family: Arial; -fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        <Label fx:id="lblSubtitulo"
               text="Selecciona las listas donde añadir la empresa"
               style="-fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.85);"
               wrapText="true"/>
    </VBox>

    <!-- Lista de checkboxes (se rellena desde el controller) -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                style="-fx-background-color: transparent; -fx-background: transparent;"
                prefHeight="220" maxHeight="300">
        <VBox fx:id="contenedorListas" spacing="4">
            <padding>
                <Insets top="12" right="20" bottom="8" left="20"/>
            </padding>
            <!-- Los CheckBox se añaden dinámicamente desde el controller -->
        </VBox>
    </ScrollPane>

    <!-- Mensaje cuando no hay listas -->
    <Label fx:id="lblSinListas"
           text="No tienes listas creadas.\nVe a la sección Listas para crear una."
           visible="false" managed="false"
           style="-fx-font-family: Arial; -fx-font-size: 13px; -fx-text-fill: #888; -fx-text-alignment: center;"
           wrapText="true" alignment="CENTER">
        <padding>
            <Insets top="20" right="24" bottom="20" left="24"/>
        </padding>
    </Label>

    <!-- Botones de acción -->
    <HBox spacing="10" alignment="CENTER_RIGHT"
          style="-fx-border-color: #f0f0f0; -fx-border-width: 1 0 0 0;">
        <padding>
            <Insets top="14" right="20" bottom="14" left="20"/>
        </padding>
        <Button fx:id="btnCancelar" text="Cancelar" onAction="#cancelar"
                style="-fx-background-color: #f1f5f9; -fx-text-fill: #555; -fx-font-family: Arial;
                       -fx-font-size: 13px; -fx-background-radius: 10; -fx-padding: 9 20; -fx-cursor: hand;"/>
        <Button fx:id="btnGuardar" text="Guardar" onAction="#guardar"
                style="-fx-background-color: #0d9488; -fx-text-fill: white; -fx-font-family: Arial;
                       -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10;
                       -fx-padding: 9 20; -fx-cursor: hand;"/>
    </HBox>

</VBox>
