<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane  style="-fx-background-color: linear-gradient(to bottom, #4facfe 0%, #00f2fe 50%, #87CEEB 100%);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.practicas.controller.PerfilController">

    <top>
        <VBox spacing="6" style="-fx-background-color: transparent;">
            <padding>
                <Insets bottom="10" left="30" right="30" top="25" />
            </padding>
            <Label style="-fx-font-family: Arial; -fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;" text="Mi Perfil" />
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox alignment="TOP_CENTER" spacing="24" style="-fx-background-color: transparent;">
                <padding>
                    <Insets bottom="30" left="50" right="50" top="20" />
                </padding>

                <!-- ── Avatar con iniciales ────────────────────────────────── -->
                <VBox alignment="CENTER" maxWidth="100" prefHeight="100" prefWidth="100" style="-fx-background-color: rgba(255,255,255,0.25); -fx-background-radius: 50; -fx-border-color: rgba(255,255,255,0.4); -fx-border-radius: 50; -fx-border-width: 2;">
                    <!-- El controller settea el texto con las iniciales: lblIniciales.setText("JG") -->
                    <Label fx:id="lblIniciales" style="-fx-font-family: Arial; -fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white;" text="??" />
                </VBox>

                <!-- Nombre completo -->
                <Label fx:id="lblNombreCompleto" style="-fx-font-family: Arial; -fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: white;" text="Nombre Apellidos" />

                <!-- Badge de rol -->
                <Label fx:id="lblRol" style="-fx-background-color: rgba(255,255,255,0.25); -fx-background-radius: 20; -fx-padding: 7 20; -fx-font-family: Arial; -fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: white; -fx-letter-spacing: 1;" text="PROFESOR" />

                <!-- ── Tarjeta de información ─────────────────────────────── -->
                <VBox maxWidth="700" style="-fx-background-color: rgba(255,255,255,0.18); -fx-background-radius: 18; -fx-padding: 22 24;">

                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <Label style="-fx-font-size: 18px; -fx-text-fill: white;" text="✉" />
                        <Label fx:id="lblEmail" style="-fx-font-family: Arial; -fx-font-size: 15px; -fx-text-fill: white;" text="usuario@centro.es" />
                    </HBox>

                    <Region prefHeight="1" style="-fx-background-color: rgba(255,255,255,0.2); -fx-margin: 12 0;" />
                    <Region prefHeight="14" />

                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <Label style="-fx-font-size: 18px; -fx-text-fill: white;" text="ID" />
                        <Label fx:id="lblNif" style="-fx-font-family: Arial; -fx-font-size: 15px; -fx-text-fill: white;" text="12345678A" />
                    </HBox>

                    <Region prefHeight="14" />

                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <Label style="-fx-font-size: 18px; -fx-text-fill: white;" text="⌂" />
                        <Label fx:id="lblCentro" style="-fx-font-family: Arial; -fx-font-size: 15px; -fx-text-fill: white;" text="CIFP Villa de Agüimes" />
                    </HBox>
                </VBox>

                <!-- ── Botón Cerrar sesión ───────────────────────────────── -->
                <Button maxWidth="700" onAction="#cerrarSesion" prefHeight="50" style="-fx-background-color: rgba(255,255,255,0.18); -fx-text-fill: #FF5252; -fx-font-family: Arial; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 18; -fx-cursor: hand;" text="⬡  Cerrar sesión" />

                <!-- Versión -->
                <Label style="-fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.5);" text="Versión 1.0.0" />

            </VBox>
        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 20 20 0 0; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 12, 0, 0, -3);">
            <padding>
                <Insets bottom="18" left="10" right="10" top="14" />
            </padding>
            <VBox alignment="CENTER" onMouseClicked="#volverAEmpresas" style="-fx-cursor: hand;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 20px; -fx-text-fill: #999;" text="⌂" />
                <Label style="-fx-font-family: Arial; -fx-font-size: 11px; -fx-text-fill: #999999;" text="FCT-Seek" />
            </VBox>
            <VBox alignment="CENTER" onMouseClicked="#abrirBusqueda" style="-fx-cursor: hand;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 20px; -fx-text-fill: #999;" text="⚲" />
                <Label style="-fx-font-family: Arial; -fx-font-size: 11px; -fx-text-fill: #999999;" text="Buscar Empre..." />
            </VBox>
            <VBox alignment="CENTER" onMouseClicked="#abrirListas" style="-fx-cursor: hand;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 20px;" text="☰" />
                <Label style="-fx-font-family: Arial; -fx-font-size: 11px; -fx-text-fill: #999999;" text="Mis Listas" />
            </VBox>
            <VBox alignment="CENTER" style="-fx-cursor: hand;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 20px; -fx-text-fill: #4facfe;" text="●" />
                <Label style="-fx-font-family: Arial; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #4facfe;" text="Mi Perfil" />
            </VBox>
        </HBox>
    </bottom>
</BorderPane>
