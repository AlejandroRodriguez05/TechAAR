<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane 
            style="-fx-background-color: linear-gradient(to bottom, #4facfe 0%, #00f2fe 50%, #87CEEB 100%);"
            xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25"
            fx:controller="com.practicas.controller.EmpresasController">

    <top>
        <VBox spacing="16" style="-fx-background-color: transparent;">
            <padding>
                <Insets bottom="10" left="30" right="30" top="25" />
            </padding>

            <HBox alignment="CENTER_LEFT">
                <VBox spacing="4">
                    <Label fx:id="lblSaludo"
                           style="-fx-font-family: Arial; -fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"
                           text="Hola, Usuario" />
                    <Label fx:id="lblInfo"
                           style="-fx-font-family: Arial; -fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.85);"
                           text="x empresas disponibles" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <!-- Botón + solo visible para admin -->
                <Button fx:id="btnAdd" onAction="#mostrarDialogoAnadir" prefHeight="44" prefWidth="44"
                        style="-fx-background-color: rgba(255,255,255,0.25); -fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold; -fx-background-radius: 22; -fx-cursor: hand;"
                        text="+" visible="false" managed="false" />
            </HBox>

            <!-- Filtros rápidos -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label fx:id="filtroNuevas" onMouseClicked="#filtrarNuevas"
                       style="-fx-background-color: rgba(255,255,255,0.25); -fx-background-radius: 20; -fx-padding: 9 18; -fx-font-family: Arial; -fx-font-size: 13px; -fx-text-fill: white; -fx-cursor: hand;"
                       text="Nuevas" />
                <Label fx:id="filtroTop" onMouseClicked="#filtrarTopValoradas"
                       style="-fx-background-color: rgba(255,255,255,0.25); -fx-background-radius: 20; -fx-padding: 9 18; -fx-font-family: Arial; -fx-font-size: 13px; -fx-text-fill: white; -fx-cursor: hand;"
                       text="Top valoradas" />
                <Label fx:id="filtroCercanas" onMouseClicked="#filtrarCercanas"
                       style="-fx-background-color: rgba(255,255,255,0.25); -fx-background-radius: 20; -fx-padding: 9 18; -fx-font-family: Arial; -fx-font-size: 13px; -fx-text-fill: white; -fx-cursor: hand;"
                       text="Cercanas" />
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="10" style="-fx-background-color: transparent;">
            <padding>
                <Insets bottom="10" left="30" right="30" top="8" />
            </padding>

            <HBox alignment="CENTER_LEFT">
                <Label fx:id="lblTituloSeccion"
                       style="-fx-font-family: Arial; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"
                       text="Todas las empresas" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="lblBadge"
                       style="-fx-background-color: rgba(255,255,255,0.25); -fx-background-radius: 14; -fx-padding: 5 14; -fx-font-family: Arial; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: white;"
                       text="0" />
            </HBox>

            <ScrollPane fx:id="scrollEmpresas" fitToWidth="true" hbarPolicy="NEVER"
                        style="-fx-background-color: transparent; -fx-background: transparent;"
                        VBox.vgrow="ALWAYS">
                <!-- controller: crearCardEmpresa(empresa) → card con nombre, rating, ciudad, dpto, contactado, ciclos -->
                <VBox fx:id="listaEmpresas" spacing="14" style="-fx-background-color: transparent;" />
            </ScrollPane>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER"
              style="-fx-background-color: white; -fx-background-radius: 20 20 0 0; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 12, 0, 0, -3);">
            <padding>
                <Insets bottom="18" left="10" right="10" top="14" />
            </padding>
            <VBox alignment="CENTER" style="-fx-cursor: hand;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 20px;" text="🏠" />
                <Label style="-fx-font-family: Arial; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #4facfe;"
                       text="FCT-Seek" />
            </VBox>
            <VBox alignment="CENTER" onMouseClicked="#abrirBusqueda" style="-fx-cursor: hand;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 20px;" text="🔍" />
                <Label style="-fx-font-family: Arial; -fx-font-size: 11px; -fx-text-fill: #999999;" text="Buscar Empre..." />
            </VBox>
            <VBox alignment="CENTER" onMouseClicked="#mostrarMisListas" style="-fx-cursor: hand;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 20px;" text="☰" />
                <Label style="-fx-font-family: Arial; -fx-font-size: 11px; -fx-text-fill: #999999;" text="Mis Listas" />
            </VBox>
            <VBox alignment="CENTER" onMouseClicked="#abrirPerfil" style="-fx-cursor: hand;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 20px;" text="👤" />
                <Label style="-fx-font-family: Arial; -fx-font-size: 11px; -fx-text-fill: #999999;" text="Mi Perfil" />
            </VBox>
        </HBox>
    </bottom>
</BorderPane>
