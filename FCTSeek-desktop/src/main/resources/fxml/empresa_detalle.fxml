<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: linear-gradient(to bottom, #4facfe 0%, #00f2fe 50%, #87CEEB 100%);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.practicas.controller.EmpresaDetalleController">

    <top>
        <VBox spacing="8" style="-fx-background-color: transparent;">
            <padding>
                <Insets bottom="15" left="30" right="30" top="20" />
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Button onAction="#volver" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-family: Arial; -fx-font-size: 13px; -fx-background-radius: 15; -fx-padding: 8 15; -fx-cursor: hand;" text="← Volver" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="btnAnadirALista" onAction="#abrirDialogoAnadirALista" style="-fx-background-color: white; -fx-text-fill: #0d9488; -fx-font-family: Arial; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 15; -fx-padding: 8 15; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 6, 0, 0, 2);" text="+  Añadir a lista" />
            </HBox>
            <Label fx:id="lblNombreEmpresa" style="-fx-font-family: Arial; -fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: white;" text="Nombre de la Empresa" wrapText="true" />
            <HBox alignment="CENTER_LEFT" spacing="6">
                <Label fx:id="lblEstrellas" style="-fx-font-size: 20px; -fx-text-fill: #FFD700;" text="★★★★☆" />
                <Label fx:id="lblValoracion" style="-fx-font-family: Arial; -fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: white;" text="4.5" />
                <Label fx:id="lblNumValoraciones" style="-fx-font-family: Arial; -fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.75);" text="(12 valoraciones)" />
            </HBox>
            <HBox fx:id="contenedorChipsDpto" alignment="CENTER_LEFT" spacing="8" />
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="16" style="-fx-background-color: transparent;">
                <padding>
                    <Insets bottom="30" left="30" right="30" top="12" />
                </padding>

                <VBox fx:id="tarjetaPlazas" style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);">
                    <padding><Insets bottom="18" left="20" right="20" top="18" /></padding>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-font-size: 18px; -fx-text-fill: #0d9488; -fx-font-weight: bold;" text="▣" />
                        <Label style="-fx-font-family: Arial; -fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #333333;" text="Plazas disponibles" />
                    </HBox>
                    <Region prefHeight="12" />
                    <VBox fx:id="contenedorPlazas" spacing="12" />
                </VBox>

                <VBox style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);">
                    <padding><Insets bottom="18" left="20" right="20" top="18" /></padding>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-font-size: 18px; -fx-text-fill: #0d9488;" text="☎" />
                        <Label style="-fx-font-family: Arial; -fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #333333;" text="Contactado por" />
                    </HBox>
                    <Region prefHeight="12" />
                    <VBox fx:id="listaContactados" spacing="8" />
                </VBox>

                <HBox spacing="16" alignment="TOP_LEFT">
                    <VBox style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);" HBox.hgrow="ALWAYS">
                        <padding><Insets bottom="18" left="20" right="20" top="18" /></padding>
                        <Label style="-fx-font-family: Arial; -fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #333333;" text="Información de contacto" />
                        <Region prefHeight="14" />
                        <HBox alignment="TOP_LEFT" spacing="12">
                            <Label fx:id="iconDireccion" style="-fx-font-size: 16px; -fx-padding: 1 0 0 0; -fx-text-fill: #0d9488;" />
                            <Label fx:id="lblDireccion" style="-fx-font-family: Arial; -fx-font-size: 14px; -fx-text-fill: #555555;" wrapText="true" />
                        </HBox>
                        <Region prefHeight="12" />
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label fx:id="iconTelefono" style="-fx-font-size: 16px; -fx-text-fill: #0d9488;" />
                            <Label fx:id="lblTelefono" style="-fx-font-family: Arial; -fx-font-size: 14px; -fx-text-fill: #0d9488; -fx-cursor: hand;" />
                        </HBox>
                        <Region prefHeight="12" />
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label fx:id="iconEmail" style="-fx-font-size: 16px; -fx-text-fill: #0d9488;" />
                            <Label fx:id="lblEmail" style="-fx-font-family: Arial; -fx-font-size: 14px; -fx-text-fill: #0d9488; -fx-cursor: hand;" />
                        </HBox>
                        <Region prefHeight="12" />
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label fx:id="iconContacto" style="-fx-font-size: 16px; -fx-text-fill: #0d9488;" />
                            <Label fx:id="lblPersonaContacto" style="-fx-font-family: Arial; -fx-font-size: 14px; -fx-text-fill: #555555;" />
                        </HBox>
                    </VBox>
                    <VBox style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);" HBox.hgrow="ALWAYS">
                        <padding><Insets bottom="18" left="20" right="20" top="18" /></padding>
                        <Label style="-fx-font-family: Arial; -fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #333333;" text="Descripción" />
                        <Region prefHeight="10" />
                        <Label fx:id="lblDescripcion" style="-fx-font-family: Arial; -fx-font-size: 14px; -fx-text-fill: #666666;" wrapText="true" />
                    </VBox>
                </HBox>

                <VBox style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);">
                    <padding><Insets bottom="18" left="20" right="20" top="18" /></padding>
                    <Label style="-fx-font-family: Arial; -fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #333333;" text="Departamentos que acepta:" />
                    <Region prefHeight="14" />
                    <VBox fx:id="listaCiclos" spacing="14" />
                </VBox>

                <VBox style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);">
                    <padding><Insets bottom="18" left="20" right="20" top="18" /></padding>
                    <Label style="-fx-font-family: Arial; -fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #333333;" text="Comentarios" />
                    <Region prefHeight="12" />
                    <HBox spacing="0" style="-fx-background-color: #F1F5F9; -fx-background-radius: 10; -fx-padding: 4;">
                        <Button fx:id="btnTabGeneral" maxWidth="Infinity" onAction="#mostrarComentariosGenerales" prefHeight="38" style="-fx-background-color: #0d9488; -fx-text-fill: white; -fx-font-family: Arial; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="General (0)" HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnTabProfesores" maxWidth="Infinity" onAction="#mostrarComentariosProfesores" prefHeight="38" style="-fx-background-color: transparent; -fx-text-fill: #666666; -fx-font-family: Arial; -fx-font-size: 13px; -fx-background-radius: 8; -fx-cursor: hand;" text="Profesores (0)" HBox.hgrow="ALWAYS" />
                    </HBox>
                    <Label style="-fx-font-family: Arial; -fx-font-size: 11px; -fx-text-fill: #999999; -fx-padding: 8 0 4 0;" text="Visible para todos los usuarios" />
                    <Region prefHeight="8" />
                    <VBox fx:id="listaComentarios" spacing="16" />
                    <Region prefHeight="10" />
                    <Button maxWidth="Infinity" onAction="#escribirComentario" style="-fx-background-color: transparent; -fx-text-fill: #0d9488; -fx-font-family: Arial; -fx-font-size: 14px; -fx-font-weight: bold; -fx-border-color: #0d9488; -fx-border-width: 1.5; -fx-border-style: dashed; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12 0; -fx-cursor: hand;" text="Escribir comentario" />
                </VBox>

                <VBox style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 3);">
                    <padding><Insets bottom="18" left="20" right="20" top="18" /></padding>
                    <Label style="-fx-font-family: Arial; -fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #333333;" text="Acciones" />
                    <Region prefHeight="14" />
                    <HBox spacing="12">
                        <VBox fx:id="boxFavorito" alignment="CENTER" onMouseClicked="#toggleFavorito" pickOnBounds="true" prefHeight="100" spacing="10" style="-fx-background-color: #F8F8F8; -fx-background-radius: 14; -fx-cursor: hand;" HBox.hgrow="ALWAYS">
                            <Label fx:id="iconFavorito" style="-fx-font-size: 30px; -fx-text-fill: #ef4444;" />
                            <Label fx:id="lblFavoritoTexto" style="-fx-font-family: Arial; -fx-font-size: 13px; -fx-text-fill: #555555;" text="Favorito" />
                        </VBox>
                        <VBox alignment="CENTER" onMouseClicked="#abrirValorar" prefHeight="100" spacing="10" style="-fx-background-color: #F8F8F8; -fx-background-radius: 14; -fx-cursor: hand;" HBox.hgrow="ALWAYS">
                            <Label fx:id="iconValorar" style="-fx-font-size: 30px;" />
                            <Label style="-fx-font-family: Arial; -fx-font-size: 13px; -fx-text-fill: #555555;" text="Valorar" />
                        </VBox>
                    </HBox>
                    <Region prefHeight="12" />
                    <Button fx:id="btnEditarInfo" managed="false" maxWidth="Infinity" onAction="#editarEmpresa" style="-fx-background-color: white; -fx-text-fill: #0d9488; -fx-font-family: Arial; -fx-font-size: 14px; -fx-font-weight: bold; -fx-border-color: #E0E0E0; -fx-border-width: 1; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 14 0; -fx-cursor: hand;" text="Editar información" visible="false" />
                    <Region fx:id="sepEditar" managed="false" prefHeight="12" visible="false" />
                    <Button fx:id="btnMarcarContactado" maxWidth="Infinity" onAction="#marcarContactado" style="-fx-background-color: white; -fx-text-fill: #0d9488; -fx-font-family: Arial; -fx-font-size: 14px; -fx-font-weight: bold; -fx-border-color: #E0E0E0; -fx-border-width: 1; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 14 0; -fx-cursor: hand;" text="Marcar contactado" />
                </VBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>