<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: linear-gradient(to bottom, #4facfe 0%, #00f2fe 50%, #87CEEB 100%);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.practicas.controller.AnadirEmpresaController">

    <top>
        <VBox spacing="10" style="-fx-background-color: transparent;">
            <padding>
                <Insets bottom="15" left="20" right="20" top="20" />
            </padding>

            <!-- Navegación -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Button onAction="#cancelar" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-family: Arial; -fx-font-size: 13px; -fx-background-radius: 15; -fx-padding: 8 15; -fx-cursor: hand;" text="← Cancelar" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="btnGuardar" onAction="#guardarEmpresa" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-family: Arial; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 15; -fx-padding: 8 20; -fx-cursor: hand;" text="💾 Guardar" />
            </HBox>

            <!-- Título -->
            <Label fx:id="lblTitulo" style="-fx-font-family: Arial; -fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" text="Nueva Empresa" />
            <Label style="-fx-font-family: Arial; -fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.8);" text="Completa la información de la empresa" />
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox alignment="TOP_CENTER" spacing="20" style="-fx-background-color: transparent;">
                <padding>
                    <Insets bottom="30" left="50" right="50" top="10" />
                </padding>

                <!-- ══ Tarjeta: Información Básica ══ -->
                <VBox maxWidth="1762.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 3);">
                    <padding>
                        <Insets bottom="20" left="25" right="25" top="20" />
                    </padding>

                    <Label style="-fx-font-family: Arial; -fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #333333;" text="📋 Información Básica" />
                    <Region prefHeight="15" />

                    <VBox spacing="5">
                        <Label style="-fx-font-family: Arial; -fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #555555;" text="Nombre de la empresa *" />
                        <TextField fx:id="txtNombre" prefHeight="40" promptText="Ej: TechSolutions Canarias S.L." style="-fx-background-color: #F5F5F5; -fx-background-radius: 8; -fx-border-color: transparent; -fx-font-size: 14px;" />
                    </VBox>
                    <Region prefHeight="15" />

                    <VBox spacing="5">
                        <Label style="-fx-font-family: Arial; -fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #555555;" text="Descripción" />
                        <TextArea fx:id="txtDescripcion" prefHeight="100" promptText="Describe la actividad de la empresa..." style="-fx-background-color: #F5F5F5; -fx-background-radius: 8;" wrapText="true" />
                    </VBox>
                </VBox>

                <!-- ══ Tarjeta: Ubicación ══ -->
                <VBox maxWidth="1765.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 3);">
                    <padding>
                        <Insets bottom="20" left="25" right="25" top="20" />
                    </padding>

                    <Label style="-fx-font-family: Arial; -fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #333333;" text="📍 Ubicación" />
                    <Region prefHeight="15" />

                    <VBox spacing="5">
                        <Label style="-fx-font-family: Arial; -fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #555555;" text="Dirección" />
                        <TextField fx:id="txtDireccion" prefHeight="40" promptText="Ej: C/ León y Castillo, 45, 2º" style="-fx-background-color: #F5F5F5; -fx-background-radius: 8; -fx-border-color: transparent; -fx-font-size: 14px;" />
                    </VBox>
                    <Region prefHeight="15" />

                    <HBox spacing="15">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-family: Arial; -fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #555555;" text="Ciudad *" />
                            <TextField fx:id="txtCiudad" prefHeight="40" promptText="Ej: Las Palmas de G.C." style="-fx-background-color: #F5F5F5; -fx-background-radius: 8; -fx-border-color: transparent; -fx-font-size: 14px;" />
                        </VBox>
                        <VBox prefWidth="150" spacing="5">
                            <Label style="-fx-font-family: Arial; -fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #555555;" text="Código Postal" />
                            <TextField fx:id="txtCodigoPostal" prefHeight="40" promptText="Ej: 35003" style="-fx-background-color: #F5F5F5; -fx-background-radius: 8; -fx-border-color: transparent; -fx-font-size: 14px;" />
                        </VBox>
                    </HBox>
                </VBox>

                <!-- ══ Tarjeta: Contacto ══ -->
                <VBox maxWidth="1766.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 3);">
                    <padding>
                        <Insets bottom="20" left="25" right="25" top="20" />
                    </padding>

                    <Label style="-fx-font-family: Arial; -fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #333333;" text="📞 Contacto de la Empresa" />
                    <Region prefHeight="15" />

                    <HBox spacing="15">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-family: Arial; -fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #555555;" text="Teléfono" />
                            <TextField fx:id="txtTelefono" prefHeight="40" promptText="Ej: 928 123 456" style="-fx-background-color: #F5F5F5; -fx-background-radius: 8; -fx-border-color: transparent; -fx-font-size: 14px;" />
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-family: Arial; -fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #555555;" text="Email" />
                            <TextField fx:id="txtEmail" prefHeight="40" promptText="Ej: info@empresa.com" style="-fx-background-color: #F5F5F5; -fx-background-radius: 8; -fx-border-color: transparent; -fx-font-size: 14px;" />
                        </VBox>
                    </HBox>
                    <Region prefHeight="15" />

                    <VBox spacing="5">
                        <Label style="-fx-font-family: Arial; -fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #555555;" text="Página Web" />
                        <TextField fx:id="txtWeb" prefHeight="40" promptText="Ej: https://www.empresa.com" style="-fx-background-color: #F5F5F5; -fx-background-radius: 8; -fx-border-color: transparent; -fx-font-size: 14px;" />
                    </VBox>
                </VBox>

                <!-- ══ Tarjeta: Persona de Contacto ══ -->
                <VBox maxWidth="1756.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 3);">
                    <padding>
                        <Insets bottom="20" left="25" right="25" top="20" />
                    </padding>

                    <Label style="-fx-font-family: Arial; -fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #333333;" text="👤 Persona de Contacto" />
                    <Region prefHeight="15" />

                    <VBox spacing="5">
                        <Label style="-fx-font-family: Arial; -fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #555555;" text="Nombre" />
                        <TextField fx:id="txtPersonaContacto" prefHeight="40" promptText="Ej: María Rodríguez" style="-fx-background-color: #F5F5F5; -fx-background-radius: 8; -fx-border-color: transparent; -fx-font-size: 14px;" />
                    </VBox>
                    <Region prefHeight="15" />

                    <HBox spacing="15">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-family: Arial; -fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #555555;" text="Teléfono" />
                            <TextField fx:id="txtTelefonoContacto" prefHeight="40" promptText="Ej: 666 123 456" style="-fx-background-color: #F5F5F5; -fx-background-radius: 8; -fx-border-color: transparent; -fx-font-size: 14px;" />
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label style="-fx-font-family: Arial; -fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #555555;" text="Email" />
                            <TextField fx:id="txtEmailContacto" prefHeight="40" promptText="Ej: contacto@empresa.com" style="-fx-background-color: #F5F5F5; -fx-background-radius: 8; -fx-border-color: transparent; -fx-font-size: 14px;" />
                        </VBox>
                    </HBox>
                </VBox>

                <!-- ══ Tarjeta: Ciclos formativos que acepta ══ -->
                <VBox maxWidth="1762.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 3);">
                    <padding><Insets bottom="25" left="25" right="25" top="20" /></padding>
                    <Label style="-fx-font-family: Arial; -fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #333333;" text="🏫 Departamentos que acepta" />
                    <Label style="-fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: #888888;" text="Selecciona los departamentos con los que trabaja esta empresa" />
                    <Region prefHeight="15" />
                    <VBox fx:id="contenedorCursos" spacing="6" />
                </VBox>

                <!-- ══ Tarjeta: Plazas a ofrecer ══ -->
                <VBox maxWidth="1762.0" style="-fx-background-color: white; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 3);">
                    <padding><Insets bottom="25" left="25" right="25" top="20" /></padding>
                    <Label style="-fx-font-family: Arial; -fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #333333;" text="📋 Plazas a ofrecer" />
                    <Label style="-fx-font-family: Arial; -fx-font-size: 12px; -fx-text-fill: #888888;" text="Configura cuántas plazas ofrece por departamento" />
                    <Region prefHeight="15" />
                    <VBox fx:id="contenedorDepartamentos" spacing="10" />
                    <Region prefHeight="15" />
                    <HBox alignment="CENTER" style="-fx-background-color: #F0FDFA; -fx-background-radius: 8; -fx-border-color: #0d9488; -fx-border-radius: 8; -fx-padding: 14;">
                        <Label fx:id="lblTotalPlazas" style="-fx-font-family: Arial; -fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #0d9488;" text="Total plazas: 0" />
                    </HBox>
                </VBox>

                <!-- Mensaje de error -->
                <Label fx:id="lblError" managed="false" maxWidth="800" style="-fx-font-family: Arial; -fx-font-size: 13px; -fx-text-fill: #FF6B6B; -fx-background-color: rgba(255,107,107,0.2); -fx-background-radius: 10; -fx-padding: 15;" text="" visible="false" />

                <!-- Botones finales -->
                <HBox alignment="CENTER" maxWidth="800" spacing="15">
                    <Button onAction="#cancelar" prefHeight="45" prefWidth="150" style="-fx-background-color: #9E9E9E; -fx-text-fill: white; -fx-font-family: Arial; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 25; -fx-cursor: hand;" text="Cancelar" />
                    <Button onAction="#guardarEmpresa" prefHeight="45" prefWidth="200" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-family: Arial; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 25; -fx-cursor: hand;" text="Guardar Empresa" />
                </HBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
