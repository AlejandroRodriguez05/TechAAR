<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane  style="-fx-background-color: linear-gradient(to bottom, #4facfe 0%, #00f2fe 50%, #87CEEB 100%);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.practicas.controller.ListaDetalleController">

    <top>
        <VBox alignment="CENTER" spacing="4" style="-fx-background-color: transparent;">
            <padding>
                <Insets bottom="15" left="30" right="30" top="20" />
            </padding>

            <!-- Botón volver (izquierda) + icono lista (centro) -->
            <HBox alignment="CENTER_LEFT">
                <Button onAction="#volverAListas" style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-family: Arial; -fx-font-size: 13px; -fx-background-radius: 15; -fx-padding: 8 15; -fx-cursor: hand;" text="← Volver" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="btnEliminarLista" onAction="#eliminarLista" style="-fx-background-color: rgba(255,80,80,0.8); -fx-text-fill: white; -fx-font-family: Arial; -fx-font-size: 13px; -fx-background-radius: 15; -fx-padding: 8 15; -fx-cursor: hand;" text="Eliminar" />
            </HBox>

            <!-- Icono de la lista (dinámico según tipo) -->
            <VBox fx:id="contenedorIconoLista" alignment="CENTER" prefHeight="72" prefWidth="72" style="-fx-background-color: rgba(255,255,255,0.25); -fx-background-radius: 36;">
                <Label fx:id="iconoLista" style="-fx-font-size: 34px; -fx-text-fill: #ef4444;" text="♥" />
            </VBox>

            <!-- Nombre y contador -->
            <Label fx:id="lblNombreLista" style="-fx-font-family: Arial; -fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" text="Favoritos" />
            <Label fx:id="lblEmpresasCount" style="-fx-font-family: Arial; -fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.8);" text="0 empresas" />
        </VBox>
    </top>

    <center>
        <VBox spacing="10" style="-fx-background-color: transparent;">
            <padding>
                <Insets bottom="10" left="30" right="30" top="10" />
            </padding>

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                <!-- controller: crearCardEmpresaEnLista(empresa) →
                       card blanco igual que busqueda pero con botón ✕ rojo arriba-derecha
                       (superpuesto sobre el badge de rating)
                -->
                <VBox fx:id="listaEmpresas" spacing="14" style="-fx-background-color: transparent;">
                </VBox>
            </ScrollPane>

            <!-- Estado vacío -->
            <VBox fx:id="estadoVacio" alignment="CENTER" managed="false" spacing="16" visible="false" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets top="60" />
                </padding>
                <Label style="-fx-font-size: 52px; -fx-text-fill: white;" text="☰" />
                <Label style="-fx-font-family: Arial; -fx-font-size: 17px; -fx-text-fill: white;" text="Esta lista está vacía" />
                <Label style="-fx-font-family: Arial; -fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.75);" text="Añade empresas desde el detalle de empresa" />
            </VBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: white; -fx-background-radius: 20 20 0 0; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 12, 0, 0, -3);">
            <padding>
                <Insets bottom="18" left="10" right="10" top="14" />
            </padding>
            <VBox alignment="CENTER" onMouseClicked="#volverAEmpresas" style="-fx-cursor: hand;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 20px; -fx-text-fill: #999;" text="⌂" />
                <Label style="-fx-font-family: Arial; -fx-font-size: 11px; -fx-text-fill: #999999;" text="FCT-Seek" />
            </VBox>
            <VBox alignment="CENTER" onMouseClicked="#abrirBusqueda" style="-fx-cursor: hand;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 20px; -fx-text-fill: #999;" text="⚲" />
                <Label style="-fx-font-family: Arial; -fx-font-size: 11px; -fx-text-fill: #999999;" text="Buscar Empre..." />
            </VBox>
            <VBox alignment="CENTER" onMouseClicked="#volverAListas" style="-fx-cursor: hand;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 20px;" text="☰" />
                <Label style="-fx-font-family: Arial; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #4facfe;" text="Mis Listas" />
            </VBox>
            <VBox alignment="CENTER" onMouseClicked="#abrirPerfil" style="-fx-cursor: hand;" HBox.hgrow="ALWAYS">
                <Label style="-fx-font-size: 20px; -fx-text-fill: #999;" text="●" />
                <Label style="-fx-font-family: Arial; -fx-font-size: 11px; -fx-text-fill: #999999;" text="Mi Perfil" />
            </VBox>
        </HBox>
    </bottom>
</BorderPane>
